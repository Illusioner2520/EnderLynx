{
  "name": "EnderLynx",
  "version": "0.10.3",
  "main": "main.js",
  "scripts": {
    "start": "electron-forge start",
    "make": "electron-forge make",
    "installer": "makensis installer/installer.nsi",
    "updater:windows": "cd updater && cargo build --release && cd .. && copy updater\\target\\release\\updater.exe up.exe",
    "build:windows": "electron-rebuild && npm run updater:windows && npm run make && npm run installer",
    "build:linux": "flatpak remote-add --if-not-exists --user flathub https://dl.flathub.org/repo/flathub.flatpakrepo && electron-rebuild && npm run make",
    "build:macos": "electron-rebuild && npm run make"
  },
  "author": "Illusioner",
  "license": "MIT",
  "description": "The best Minecraft launcher.",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-flatpak": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^4.0.4",
    "electron": "^41.5.1"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "ace-builds": "^1.43.6",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.6.2",
    "create-desktop-shortcuts": "^1.11.1",
    "discord-rpc": "^4.0.1",
    "electron-window-state": "^5.0.3",
    "form-data": "^4.0.5",
    "markdown-it": "^14.1.1",
    "msmc": "^5.0.5",
    "p-limit": "^7.3.0",
    "png-to-ico": "^3.0.1",
    "prismarine-nbt": "^2.8.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "skinview3d": "^3.4.1",
    "string-argv": "^0.3.2",
    "toml": "^3.0.0",
    "winreg": "^1.2.5"
  }
}
